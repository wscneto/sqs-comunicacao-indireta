# Modelo de configuração. Copie este arquivo para .env e preencha os valores.
# NUNCA coloque credenciais AWS aqui. Use `aws configure` para isso.
#
# As credenciais (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) devem ser
# configuradas via `aws configure`, que as armazena em ~/.aws/credentials.

# Região AWS onde as filas foram criadas
AWS_REGION=sa-east-1

# URL da fila Standard (obtida após rodar scripts/create_queues.py)
STANDARD_QUEUE_URL=

# URL da fila FIFO (obtida após rodar scripts/create_queues.py)
FIFO_QUEUE_URL=

# URL da Dead-Letter Queue Standard (DLQ da fila Standard).
# Obtida após rodar scripts/create_queues.py.
DLQ_URL=

# URL da Dead-Letter Queue FIFO (DLQ da fila FIFO).
# O SQS exige que a DLQ seja do mesmo tipo da fila de origem.
DLQ_FIFO_URL=

# Tempo de long polling em segundos (0 a 20).
# Long polling reduz chamadas vazias e diminui custo na AWS.
WAIT_TIME_SECONDS=10

# Quantas vezes uma mensagem pode falhar no processamento antes de ir para a DLQ.
# Após MAX_RECEIVE_COUNT falhas, a mensagem é movida automaticamente para a DLQ.
MAX_RECEIVE_COUNT=3

# (Opcional) Endpoint do LocalStack para testes locais sem AWS real.
# Deixe em branco ou remova para usar a AWS real.
# LOCALSTACK_ENDPOINT_URL=http://localhost:4566
